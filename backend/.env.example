# ========================================
# WebAI Auditor - Environment Configuration
# ========================================
# Copy this file to .env and configure for your environment

# ----------------------------------------
# Application Settings
# ----------------------------------------
APP_NAME="WebAI Auditor"
APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en

# Application Key (generate with: php artisan key:generate)
APP_KEY=

# Force HTTPS in production
FORCE_HTTPS=false

# ----------------------------------------
# Logging Configuration
# ----------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_STACK=single

# ----------------------------------------
# Database Configuration
# ----------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=webai_auditor
DB_USERNAME=root
DB_PASSWORD=

# Database options
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ----------------------------------------
# Cache & Session Configuration
# ----------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# ----------------------------------------
# Redis Configuration (Optional)
# ----------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# ----------------------------------------
# Auditor Configuration
# ----------------------------------------
SELENIUM_HOST=http://localhost:4444
SCREENSHOT_PATH=../storage/screenshots
MAX_CRAWL_DEPTH=3
CRAWL_TIMEOUT=30

# ----------------------------------------
# External API Keys
# ----------------------------------------
# GitHub API (for searching open-source projects)
GITHUB_TOKEN=

# Google Search API
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# TinyFish / AgentQL Configuration
# Get your API key from: https://agentql.com
TINYFISH_API_KEY=your_tinyfish_api_key_here
TINYFISH_ENDPOINT=https://api.agentql.com/v1/query
TINYFISH_TIMEOUT=60
TINYFISH_RETRY_ATTEMPTS=3

# ----------------------------------------
# Production Settings
# ----------------------------------------
# Queue Configuration (Production)
QUEUE_CONNECTION=database
JOB_WORKERS=5

# Admin Secret (for protected source operations)
# Generate with: openssl rand -base64 32
ADMIN_SECRET=your_random_admin_secret_here_change_this_in_production

# Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_PERIOD=1

# API Timeout (seconds)
API_TIMEOUT=30

# ----------------------------------------
# CORS Configuration
# ----------------------------------------
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ----------------------------------------
# Feature Flags
# ----------------------------------------
FEATURE_REGISTRATION=true
FEATURE_EMAIL_VERIFICATION=false
FEATURE_ANALYTICS=false
FEATURE_MONITORING=false

# ----------------------------------------
# Mail Configuration (for notifications)
# ----------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ENABLED=false

# ----------------------------------------
# Security Headers
# ----------------------------------------
CSP_ENABLED=true
HSTS_ENABLED=true
