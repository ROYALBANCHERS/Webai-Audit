{
  "compilerOptions": {
    "module": "commonjs",
    "noEmit": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strict": false,
    "target": "es2017",
    "sourceMap": true,
    "outDir": "lib",
    "rootDir": "src",
    "lib": ["es2017"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "forceConsistentCasingInFileNames": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "lib"
  ]
}
