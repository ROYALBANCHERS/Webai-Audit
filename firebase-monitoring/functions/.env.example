# Firebase Cloud Functions Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# GEMINI AI API
# ============================================
# Get your API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative naming (also supported)
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Firebase Project Region
GCP_REGION=asia-south1

# ============================================
# SCRAPER CONFIGURATION
# ============================================
# Maximum concurrent requests in batch processing
MAX_CONCURRENT_SCRAPES=5

# Request timeout in milliseconds
SCRAPER_TIMEOUT=30000

# Maximum response size in bytes (10MB default)
MAX_CONTENT_SIZE=10485760

# ============================================
# AI CONFIGURATION
# ============================================
# Model to use for analysis
GEMINI_MODEL=gemini-2.0-flash-exp

# Fallback model
GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# Maximum tokens in AI response
MAX_OUTPUT_TOKENS=500

# ============================================
# NOTIFICATION CONFIGURATION
# ============================================
# SendGrid API Key (for email notifications)
SENDGRID_API_KEY=your_sendgrid_key_here

# From email address
FROM_EMAIL=noreply@yourdomain.com

# ============================================
# WEBHOOK CONFIGURATION
# ============================================
# Webhook URL for external notifications
WEBHOOK_URL=https://your-webhook-url.com/notify

# Webhook secret for verification
WEBHOOK_SECRET=your_random_secret_here

# ============================================
# DEVELOPMENT/TESTING
# ============================================
# Set to 'true' to enable debug logging
DEBUG=false

# Test mode (won't send real notifications)
TEST_MODE=false
